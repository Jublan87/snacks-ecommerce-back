# Puerto de la aplicación
PORT=4000

# Entorno de ejecución
NODE_ENV=development

# Base de datos
DATABASE_URL=postgresql://user:password@localhost:5432/snacks_db

# JWT
JWT_SECRET=your-secret-key-here-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# Cookies
COOKIE_SECRET=your-cookie-secret-here-minimum-32-characters-long

# Envío
FREE_SHIPPING_THRESHOLD=10000
SHIPPING_COST=1500

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate limiting — TTL en segundos, limit en cantidad de requests por TTL
# Valores de desarrollo (permisivos). Para producción usar valores más estrictos:
THROTTLE_DEFAULT_TTL=60
THROTTLE_DEFAULT_LIMIT=1000
THROTTLE_LOGIN_TTL=60
THROTTLE_LOGIN_LIMIT=50
THROTTLE_REGISTER_TTL=60
THROTTLE_REGISTER_LIMIT=30
THROTTLE_ADMIN_TTL=60
THROTTLE_ADMIN_LIMIT=500

# Cloudinary (servicio de imágenes)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
