    {
      "name": "Carrito",
      "item": [
        {
          "name": "Obtener carrito",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/cart",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "cart"]
            },
            "description": "Obtiene el carrito del usuario autenticado. Si no existe, lo crea vacío automáticamente.\n\nRequiere: copiar el accessToken del response de Login y pegarlo en la variable de colección {{token}}."
          },
          "response": []
        },
        {
          "name": "Agregar item al carrito",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:4000/api/cart/items",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "cart", "items"]
            },
            "description": "Agrega un producto al carrito. Si el item ya existe, incrementa la cantidad.\n\nVariables a configurar:\n- {{token}}: JWT del usuario (copiar accessToken del response de Login)\n- {{productId}}: UUID del producto (copiar data.items[n].id de GET /api/products)\n\nErrores:\n- 404: producto no encontrado\n- 400 PRODUCT_INACTIVE: producto inactivo\n- 400 INSUFFICIENT_STOCK: stock insuficiente (response incluye details.available y details.requested)"
          },
          "response": []
        },
        {
          "name": "Actualizar cantidad de item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 5\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:4000/api/cart/items/{{cartItemId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "cart", "items", "{{cartItemId}}"]
            },
            "description": "Reemplaza la cantidad de un item del carrito (no incrementa, reemplaza directamente).\n\nVariables a configurar:\n- {{token}}: JWT del usuario\n- {{cartItemId}}: UUID del item (copiar data.items[n].id de GET /api/cart o del response de Agregar item)\n\nErrores:\n- 404: item no encontrado o no pertenece al usuario\n- 400 INSUFFICIENT_STOCK: stock insuficiente para la nueva cantidad"
          },
          "response": []
        },
        {
          "name": "Eliminar item del carrito",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/cart/items/{{cartItemId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "cart", "items", "{{cartItemId}}"]
            },
            "description": "Elimina un item específico del carrito.\n\nVariables a configurar:\n- {{token}}: JWT del usuario\n- {{cartItemId}}: UUID del item a eliminar\n\nErrores:\n- 404: item no encontrado o no pertenece al usuario"
          },
          "response": []
        },
        {
          "name": "Vaciar carrito",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:4000/api/cart",
              "protocol": "http",
              "host": ["localhost"],
              "port": "4000",
              "path": ["api", "cart"]
            },
            "description": "Elimina todos los items del carrito del usuario autenticado.\n\nVariables a configurar:\n- {{token}}: JWT del usuario"
          },
          "response": []
        }
      ]
    }
